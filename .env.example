# Kalshi Trade API - copy this file to `.env`, fill in real values, never commit `.env`.
#
# KALSHI_API_PRIVATE_KEY must be a valid PEM string (from Kalshi key download). Inside the
# double quotes use REAL line breaks - same layout as the .pem file. Do not put placeholder
# text like dots or the word "paste" inside the quotes (that causes PEM parse errors).
#
#   KALSHI_API_KEY_ID=key-xxxxxxxxxxxxxxxx
#   KALSHI_API_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
#   <first line of base64 from your .pem file>
#   <second line of base64>
#   (every line from the file)
#   -----END RSA PRIVATE KEY-----"
#
# Common failures:
#   - Literal `...` or comment text left inside the quoted block (cryptography: InvalidByte, 46 is often `.`)
#   - Spaces inserted in the middle of base64 (e.g. from chat) - copy from the .pem file only
#   - Smart quotes `"` instead of ASCII `"` - must be straight double quotes
#   - Missing newline after BEGIN line before first base64 line
#
# If a key was ever pasted into chat or committed, rotate it in Kalshi and use a new PEM.

KALSHI_API_KEY_ID=your-api-key-id-here
# After copying to .env: put your real PEM between the quotes below. Delete the @@ line and
# paste every base64 line from Kalshi .pem (no dots, no spaces inside lines, no placeholder text).
KALSHI_API_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
@@PASTE_ALL_LINES_FROM_YOUR_KALSHI_DOWNLOADED_PEM_HERE_THEN_DELETE_THIS_LINE@@
-----END RSA PRIVATE KEY-----"
