# Optional: copy to /etc/kalshi/observability.env (644). install-systemd.sh creates this from the example on first run.
# Used by kalshi-observability.service — Tier 2 (CloudWatch metrics + optional S3 text snapshots).
#
# IAM (instance profile on EC2): allow at least
#   cloudwatch:PutMetricData on *
#   s3:PutObject on arn:aws:s3:::YOUR_BUCKET/kalshi/tier2/*   (if S3_TIER2_URI is set)

# CloudWatch metric namespace (AWS console: CloudWatch > Metrics > All metrics > KalshiData)
CLOUDWATCH_NAMESPACE=KalshiData

# Dimension on every metric (use prod / staging / home)
KALSHI_ENV=prod

# Optional: s3://bucket/prefix/ — each run uploads prefix/<UTC-timestamp>/health_report.json and dataset_stats.txt
# S3_TIER2_URI=s3://my-bucket/kalshi/tier2/

# If S3_TIER2_URI is set: also upload data/kalshi/state/ops_snapshot.json when present (from institutional_ops_console.py).
# UPLOAD_OPS_SNAPSHOT=0
# OPS_SNAPSHOT_PATH=/opt/kalshi-pipeline/data/kalshi/state/ops_snapshot.json

# Required for the AWS CLI (use the same region as your EC2 / dashboard).
AWS_REGION=us-east-1
