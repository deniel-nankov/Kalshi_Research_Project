# Copy to /etc/kalshi/observability.env (chmod 644). install-systemd.sh seeds this on first run.
# Used by kalshi-observability.service (daily, after kalshi-health) and optionally after verified full-dataset S3 sync.
#
# --- Turn on Tier 2 (production-style) ---
# 1. Set AWS_REGION to your EC2 region.
# 2. Keep CLOUDWATCH_NAMESPACE + KALSHI_ENV (or adjust).
# 3. Uncomment S3_TIER2_URI so each run uploads a timestamped folder:
#      health_report.json, dataset_stats.txt, and (if enabled) ops_snapshot.json
# 4. IAM on the instance: cloudwatch:PutMetricData; s3:PutObject on that prefix.
# 5. kalshi-health.timer must run first so data/kalshi/state/health_report.json exists.
# 6. For ops_snapshot uploads: run kalshi-ops-console.service (or --once) so ops_snapshot.json exists; set UPLOAD_OPS_SNAPSHOT=1.

CLOUDWATCH_NAMESPACE=KalshiData
KALSHI_ENV=prod
AWS_REGION=us-east-1

# Full Tier-2 S3 snapshots (dated prefix per run):
# S3_TIER2_URI=s3://YOUR_BUCKET/kalshi/tier2/

# Include ops console JSON in the same Tier-2 S3 prefix when present:
# UPLOAD_OPS_SNAPSHOT=1
# OPS_SNAPSHOT_PATH=/opt/kalshi-pipeline/data/kalshi/state/ops_snapshot.json

# If aws lives outside default PATH for a custom unit, set:
# AWS_CLI_BIN=/usr/local/bin/aws
