# Verified dataset upload (institutional gate + aws s3 sync). Used by kalshi-s3-verified-sync.timer on EC2.
#
# 1. Set S3_KALSHI_URI to your bucket or access-point prefix (see scripts/sync_kalshi_data_to_s3.sh).
# 2. Set ENABLE_KALSHI_S3_VERIFIED_SYNC=1
# 3. sudo systemctl start kalshi-s3-verified-sync.service   # test once
#    journalctl -u kalshi-s3-verified-sync.service -n 200
#
# Optional (same names as sync_verified_dataset_to_s3.sh):
#   SKIP_ORPHAN_AUDIT=1
#   APPLY_REPAIR=1

ENABLE_KALSHI_S3_VERIFIED_SYNC=0
S3_KALSHI_URI=
