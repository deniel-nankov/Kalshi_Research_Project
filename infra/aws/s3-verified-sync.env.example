# Verified full-tree S3 upload: institutional gate + aws s3 sync of data/kalshi/
# Copy to /etc/kalshi/s3-verified-sync.env (chmod 644). Used by kalshi-s3-verified-sync.timer / .service.
#
# --- Pristine data prerequisite (must pass preflight) ---
# On EC2, Parquet must be REAL files — not Git LFS pointers. If preflight reports git_lfs_pointer:
#   git lfs pull   OR   rsync data/kalshi from a machine with full files   OR   rebuild via update_forward / backfill.
# Optional hardening before upload (maintenance window): scripts/institutional_maintenance.sh --execute
#   (see script header) or infra/aws/server-data-perfection.sh when appropriate.
#
# --- Enable verified upload ---
# 1. Set S3_KALSHI_URI to the bucket/prefix for the full dataset (see scripts/sync_kalshi_data_to_s3.sh).
# 2. ENABLE_KALSHI_S3_VERIFIED_SYNC=1
# 3. sudo systemctl start kalshi-s3-verified-sync.service
#    journalctl -u kalshi-s3-verified-sync.service -n 200 --no-pager
#
# --- After a successful sync, also run Tier 2 (CloudWatch + S3 tier2 snapshots) ---
# Configure /etc/kalshi/observability.env first (S3_TIER2_URI, AWS_REGION, etc.), then set:
# RUN_TIER2_PUBLISH_AFTER_SYNC=1
# (Reads observability.env from disk; uses data/kalshi/state/health_report.json from the last health run.)
#
# Optional gate tuning:
#   SKIP_ORPHAN_AUDIT=1
#   APPLY_REPAIR=1

ENABLE_KALSHI_S3_VERIFIED_SYNC=0
S3_KALSHI_URI=

RUN_TIER2_PUBLISH_AFTER_SYNC=0
