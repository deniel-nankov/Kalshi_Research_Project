# Copy to /etc/kalshi/ops-console.env (install-systemd.sh creates on first run).
# Used by kalshi-ops-console.service - headless ops snapshot for S3 / CloudWatch.

# Seconds between writes to data/kalshi/state/ops_snapshot.json
OPS_CONSOLE_INTERVAL=300

# Optional: one JSON line per refresh (CloudWatch Logs agent can tail this file)
# OPS_CONSOLE_LOG_FILE=/var/log/kalshi/ops_console.log
