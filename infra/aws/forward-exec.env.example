# Copy to /etc/kalshi/forward-exec.env (install-systemd.sh does this on first run).
# systemd EnvironmentFile: optional extra CLI args for scripts/update_forward.py
#
# Default: full forward pull (markets + trades). Recommended for 24/7 collection.
UPDATE_FORWARD_EXTRA_ARGS=

# If you truly only want market rows (no new trades, trade watermark unchanged), use:
# UPDATE_FORWARD_EXTRA_ARGS=--markets-only

# Heavy catch-up (optional):
# UPDATE_FORWARD_EXTRA_ARGS="--chunk-days 7 --progress-verbose"
