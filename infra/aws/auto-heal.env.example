# Copy to /etc/kalshi/auto-heal.env (644). Used only if you enable kalshi-auto-heal.timer
# (see infra/aws/install-auto-heal-systemd.sh).

# Incremental orphan healing: each timer run fetches at most this many missing markets.
# 0 = disabled (default). Try 25–100 on a schedule; large backfills need many runs or a manual session.
AUTO_HEAL_ORPHANS_MAX=0

# Pause between Kalshi API calls (seconds).
AUTO_HEAL_ORPHANS_DELAY=0.25
